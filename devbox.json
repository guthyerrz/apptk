{
    "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
    "packages": [
      "jdk@17",
      "just"
    ],
    "shell": {
      "init_hook": [
        "source ./scripts/init.sh"
      ],
      "scripts": {
        "build": [
          "just build"
        ],
        "test": [
          "just test"
        ],
        "run": [
          "just run"
        ]
      }
    }
  }
  