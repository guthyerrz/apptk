{
    "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
    "packages": [
      "jdk@17",
      "just"
    ],
    "shell": {
      "init_hook": [
        "# Ensure JAVA_HOME is set (devbox usually sets it for jdk packages)",
        "if [ -z \"$JAVA_HOME\" ]; then",
        "  export JAVA_HOME=$(dirname $(dirname $(readlink -f $(which java))))",
        "fi",
        "",
        "just doctor"
      ],
      "scripts": {
        "build": [
          "just build"
        ],
        "test": [
          "just test"
        ],
        "run": [
          "just run"
        ]
      }
    }
  }
  